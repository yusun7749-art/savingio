@echo off
setlocal
cd /d "%~dp0"
set "PATCHPY=%TEMP%\savingio_homepage_scope_patch.py"
powershell -NoProfile -ExecutionPolicy Bypass -Command "[IO.File]::WriteAllBytes('%PATCHPY%',[Convert]::FromBase64String(''))"
if errorlevel 1 (
  echo PATCH PREPARE FAILED
  pause
  exit /b 1
)
set PYTHONUTF8=1
python "%PATCHPY%"
set "RC=%ERRORLEVEL%"
del /q "%PATCHPY%" >nul 2>&1
if not "%RC%"=="0" (
  echo.
  echo HOMEPAGE SAFE DEPLOY FAILED
  pause
  exit /b %RC%
)
echo.
echo HOMEPAGE SAFE DEPLOY PASS
echo https://savingio.com/
pause
