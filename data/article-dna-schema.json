{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Savingio Article DNA V2.3",
  "type": "object",
  "required": [
    "slug",
    "category",
    "article_type",
    "title",
    "description",
    "search_intent",
    "reader_state",
    "calculator",
    "calculator_name",
    "calculator_cta",
    "summary",
    "quick",
    "sections",
    "cases",
    "table",
    "checklist",
    "faq",
    "actions",
    "next_questions",
    "decision_points",
    "related_calcs",
    "related_articles",
    "notice",
    "official"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "article_type": {
      "enum": [
        "calculator",
        "application",
        "savings",
        "comparison",
        "troubleshooting",
        "health_safety"
      ]
    },
    "summary": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4
    },
    "sections": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6
    },
    "cases": {
      "type": "array",
      "minItems": 3
    },
    "checklist": {
      "type": "array",
      "minItems": 7
    },
    "faq": {
      "type": "array",
      "minItems": 5
    },
    "actions": {
      "type": "array",
      "minItems": 4
    },
    "next_questions": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 15
      }
    },
    "decision_points": {
      "type": "array",
      "minItems": 3
    },
    "related_calcs": {
      "type": "array",
      "minItems": 2
    },
    "related_articles": {
      "type": "array",
      "minItems": 2
    },
    "official": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2
      }
    },
    "search_intent": {
      "type": "string",
      "minLength": 30
    },
    "reader_state": {
      "type": "string",
      "minLength": 20
    },
    "quick": {
      "type": "string",
      "minLength": 120
    }
  }
}
